# TrustPulse environment configuration
# Copy to .env and fill in values before starting:
#   cp .env.example .env

# ── OpenEMR connection (read-only DB user) ────────────────────────────────────
OPENEMR_DB_URL=mysql+pymysql://trustpulse_ro:readonly123@mariadb:3306/openemr

# ── TrustPulse internal DB ────────────────────────────────────────────────────
TRUSTPULSE_DB_URL=sqlite:////app/data/trustpulse.db

# ── Runtime mode ─────────────────────────────────────────────────────────────
TRUSTPULSE_MODE=openemr_real

# ── Secrets — change both before any deployment ───────────────────────────────
TRUSTPULSE_PATIENT_TOKEN_SECRET=change-me-long-random-patient-token-secret
TRUSTPULSE_JWT_SECRET=change-me-long-random-jwt-secret

# ── Admin bootstrap account ───────────────────────────────────────────────────
TRUSTPULSE_ADMIN_EMAIL=admin@trustpulse.local
TRUSTPULSE_ADMIN_PASSWORD=TrustPulse@2026!

# ── Clinic branding ───────────────────────────────────────────────────────────
CLINIC_NAME=OpenEMR Lab Clinic

# ── Ingestion cadence ─────────────────────────────────────────────────────────
INGESTION_INTERVAL_SECONDS=60

# ── Demo / cold-start rule thresholds (lower for PoC demo, rise with baseline maturity) ───
# R-02 Bulk Patient Access: fire when unique patients/day exceeds this during cold-start
TRUSTPULSE_BULK_ACCESS_THRESHOLD=10
# R-08 Volume Spike: fire when total events/day exceeds this during cold-start
TRUSTPULSE_VOLUME_SPIKE_THRESHOLD=20

# ── SMTP (optional — needed for "Email" button in Reports) ────────────────────
# Leave SMTP_HOST blank to disable email sending (feature shows 503 error).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Lab-only: allow demo scenario generator to write to OpenEMR ───────────────
# Set to true ONLY in isolated lab environments. Never in production.
TRUSTPULSE_ALLOW_OPENEMR_DEMO_WRITE=false
